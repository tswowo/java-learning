<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.javaweb.mapper.DeptMapper">

    <!-- 查询所有部门信息 -->
    <select id="selectAllDept" resultType="org.javaweb.pojo.Dept">
        SELECT id,
               name,
               create_time,
               update_time
        FROM dept
        ORDER BY id
    </select>

    <!-- 删除部门信息 -->
    <delete id="deleteById">
        DELETE
        FROM dept
        WHERE id = #{id}
    </delete>

    <!-- 根据部门信息查询部门信息 -->
    <select id="selectByDept" parameterType="org.javaweb.pojo.Dept" resultType="org.javaweb.pojo.Dept">
        SELECT id,
               name,
               create_time,
               update_time
        FROM dept
        WHERE name = #{name}
    </select>

    <!-- 根据Id查询部门信息 -->
    <select id="selectById" parameterType="integer" resultType="org.javaweb.pojo.Dept">
        SELECT id,
               name,
               create_time,
               update_time
        FROM dept
        WHERE id = #{id}
    </select>

    <!-- 添加部门信息 -->
    <insert id="addDept" parameterType="org.javaweb.pojo.Dept">
        INSERT INTO dept(name, create_time, update_time)
        VALUES (#{name}, NOW(), NOW())
    </insert>

    <update id="updateDept" parameterType="org.javaweb.pojo.Dept" >
        UPDATE dept
        SET name        = #{name},
            update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>
